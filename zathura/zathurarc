# zathurarc

## Documentation:
# https://pwmt.org/projects/zathura/documentation/
# `man zathurarc`
# Arch wiki:  https://wiki.archlinux.org/title/zathura


## Font
set font "NotoSansMono 14"
# TODO: pull from environment variable for cross-application theming


#set window-height 1024
#set window-width 768

set adjust-open "width" # options: best-fit, width

# Database backend
# Plain database is deprecated; set as null to discard bookmarks and input history
set database null # options:  sqlite, plain, null

## GUI Options:  set which GUI elements are shown
# `c`: commandline, `s` is statusbar, `h`,`v` for horizontal/vertical scrollbars; none to disable all
set guioptions none

# Padding around statusbar
set statusbar-v-padding 00
set statusbar-h-padding 00

# Display only file name rather than full path
set statusbar-basename true

# Enable to allow SyncTex forward synchronization
set dbus-service true

#TODO: Disable window title -- looks ugly

# Page numbering in titlebar
set window-title-page true

# Represent home directory by tilde in label
set window-title-home-tilde true


# Clipboard
set selection-clipboard clipboard

# Allow zathura to open hyperlinks in a browser
# To follow link, press `f` and then input overlayed number of link to open in a browser
#set sandbox none


# Load modularized config files
include zathura-binds
include zathura-colors
